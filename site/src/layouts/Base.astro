---
import "../styles/global.css";
import ChartModal from "../components/ChartModal.astro";
import { base } from "../lib/base";
import { TrendingUp, Archive, LayoutGrid, Sun, Moon } from "@lucide/astro";

const { title = "아침 시장 브리핑", description = "미국·한국 증시 일일 맞춤 브리핑" } = Astro.props;
const path = Astro.url.pathname;
const isActive = (seg: string) => path.startsWith(base + seg);
const canonical = Astro.site ? new URL(path, Astro.site).href : null;
---

<!DOCTYPE html>
<html lang="ko" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content="아침 시장 브리핑" />
    <meta property="og:locale" content="ko_KR" />
    <meta name="twitter:card" content="summary" />
    <link rel="alternate" type="application/rss+xml" title="아침 시장 브리핑" href={`${base}rss.xml`} />
    <link rel="icon" href={`data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📈</text></svg>`} />
    <!-- 저장된 테마(없으면 OS 설정)를 첫 페인트 전에 적용 (FOUC 방지) + JS 활성 표시 -->
    <script is:inline>
      (function () {
        // .js 클래스가 있을 때만 reveal 요소를 숨긴다 → JS 비활성 시 콘텐츠 항상 표시
        document.documentElement.classList.add("js");
        try {
          var t = localStorage.getItem("theme");
          if (t !== "light" && t !== "dark") {
            t = window.matchMedia && window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
          }
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
    <!-- 숫자·라틴·라벨 전용 디스플레이 (시세에 고유한 인상) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" />
  </head>
  <body>
    <a href="#main" class="skip-link">본문 바로가기</a>
    <div class="aurora" aria-hidden="true">
      <b class="b1"></b>
    </div>
    <nav class="topbar" aria-label="주요 메뉴">
      <div class="topbar-inner">
        <a href={base} class="brand">
          <span class="brand-mark"><TrendingUp size={17} stroke-width={2.5} /></span>
          아침 시장 브리핑
        </a>
        <div class="topbar-right">
          <a
            href={`${base}dashboard/`}
            class:list={["nav-link", { active: isActive("dashboard") }]}
            aria-current={isActive("dashboard") ? "page" : undefined}
          >
            <LayoutGrid size={15} />
            <span class="nav-label">대시보드</span>
          </a>
          <a
            href={`${base}archive/`}
            class:list={["nav-link", { active: isActive("archive") || isActive("briefings") }]}
            aria-current={isActive("archive") ? "page" : undefined}
          >
            <Archive size={15} />
            <span class="nav-label">아카이브</span>
          </a>
          <button id="theme-toggle" type="button" aria-label="라이트 모드 전환" aria-pressed="false" title="다크/라이트 모드 전환">
            <Sun size={16} class="icon-sun" />
            <Moon size={16} class="icon-moon" />
          </button>
        </div>
      </div>
    </nav>

    <main id="main" class="container">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span class="foot-brand">
          <span class="brand-mark"><TrendingUp size={15} stroke-width={2.5} /></span>
          아침 시장 브리핑
        </span>
        <p class="foot-meta">자동 생성 브리핑 · 투자 권유가 아닌 정보 제공입니다.</p>
        <p class="foot-sub">평일 아침 브리핑 + 한국장 개장·장중·마감 스냅샷 · GitHub Actions 갱신 · 데이터 Yahoo Finance · CNN</p>
      </div>
    </footer>

    <ChartModal />

    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        if (!btn) return;
        var sync = function () {
          var light = document.documentElement.dataset.theme === "light";
          btn.setAttribute("aria-pressed", String(light));
          btn.setAttribute("aria-label", light ? "다크 모드 전환" : "라이트 모드 전환");
        };
        sync();
        btn.addEventListener("click", function () {
          var el = document.documentElement;
          var next = el.dataset.theme === "light" ? "dark" : "light";
          el.dataset.theme = next;
          try { localStorage.setItem("theme", next); } catch (e) {}
          sync();
          window.dispatchEvent(new CustomEvent("themechange", { detail: next }));
        });
      })();
    </script>

    <!-- 스크롤 등장 · 포인터 글로우 · 상단바 그림자 -->
    <script is:inline>
      (function () {
        var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        // 스크롤 등장: 뷰포트 진입 시 .is-visible 부여 (한 번만)
        var reveals = document.querySelectorAll("[data-reveal]");
        if (reduce || !("IntersectionObserver" in window)) {
          reveals.forEach(function (el) { el.classList.add("is-visible"); });
        } else {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (en) {
              if (en.isIntersecting) {
                en.target.classList.add("is-visible");
                io.unobserve(en.target);
              }
            });
          }, { rootMargin: "0px 0px -8% 0px", threshold: 0.08 });
          reveals.forEach(function (el) { io.observe(el); });
        }

        // 포인터 추적 글로우: 커서 위치를 CSS 변수로
        if (!reduce) {
          window.addEventListener("pointermove", function (e) {
            var t = e.target.closest ? e.target.closest("[data-glow]") : null;
            if (!t) return;
            var r = t.getBoundingClientRect();
            t.style.setProperty("--gx", ((e.clientX - r.left) / r.width) * 100 + "%");
            t.style.setProperty("--gy", ((e.clientY - r.top) / r.height) * 100 + "%");
          }, { passive: true });
        }

        // 상단바 스크롤 그림자
        var topbar = document.querySelector(".topbar");
        if (topbar) {
          var onScroll = function () {
            topbar.classList.toggle("scrolled", window.scrollY > 4);
          };
          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll();
        }
      })();
    </script>
  </body>
</html>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 940px;
    margin: 0 auto;
    padding: 12px 20px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-weight: 800;
    font-size: 1.02rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 9px;
    color: #fff;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    box-shadow: 0 4px 14px -2px color-mix(in srgb, var(--accent) 55%, transparent);
  }
  .topbar-right { display: flex; align-items: center; gap: 6px; }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    border-radius: 10px;
    color: var(--sub);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 600;
    transition: color 0.15s, background-color 0.15s;
  }
  .nav-link:hover { color: var(--accent); background: var(--card-hover); }
  .nav-link.active { color: var(--accent); background: var(--card-hover); }
  @media (max-width: 460px) {
    .nav-link { padding: 7px 9px; }
    .nav-label { display: none; }
  }
  #theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--sub);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background-color 0.15s;
  }
  #theme-toggle:hover { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 45%, var(--border)); }

  .container { max-width: 940px; margin: 0 auto; padding: 22px 20px 84px; }
  .footer {
    max-width: 940px;
    margin: 56px auto 0;
    padding: 26px 20px 52px;
    border-top: 1px solid var(--border);
  }
  .footer-inner { display: flex; flex-direction: column; gap: 6px; }
  .foot-brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-weight: 800;
    font-size: 0.96rem;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }
  .foot-meta { margin: 0; color: var(--sub); font-size: 0.82rem; }
  .foot-sub { margin: 0; color: var(--sub); font-size: 0.76rem; }
</style>
