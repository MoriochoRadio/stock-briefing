---
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import MarketMood from "../components/MarketMood.astro";
import QuoteCards from "../components/QuoteCards.astro";
import MarketChart from "../components/MarketChart.astro";
import BriefingArticle from "../components/BriefingArticle.astro";
import { ChevronRight } from "@lucide/astro";

const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : raw + "/";
const all = (await getCollection("briefings")).sort((a, b) => b.id.localeCompare(a.id));
const latest = all[0];
const recent = all.slice(1, 6);

let Content = null;
if (latest) ({ Content } = await render(latest));
---

<Base>
  <Hero date={latest?.id} />

  <MarketMood />

  <div class="eyebrow"><span class="tag">QUOTES</span> 주요 시세 <span class="line"></span></div>
  <QuoteCards />

  <div class="eyebrow"><span class="tag">TREND</span> 지수 추이 <span class="line"></span></div>
  <MarketChart />

  <div class="eyebrow"><span class="tag">BRIEFING</span> 오늘의 브리핑 <span class="line"></span></div>
  {latest ? (
    <BriefingArticle>
      <Content />
    </BriefingArticle>
  ) : (
    <p>아직 브리핑이 없습니다. 첫 워크플로 실행 후 생성됩니다.</p>
  )}

  {recent.length > 0 && (
    <section class="recent">
      <div class="eyebrow"><span class="tag">ARCHIVE</span> 지난 브리핑 <span class="line"></span></div>
      <div class="list">
        {recent.map((b, i) => (
          <a class="card card-lift item" data-reveal data-glow style={`--i:${i}`} href={`${base}briefings/${b.id}/`}>
            <strong>{b.id}</strong>
            <ChevronRight size={16} class="go" />
          </a>
        ))}
      </div>
      <a class="more" href={`${base}archive/`}>전체 아카이브 보기 →</a>
    </section>
  )}
</Base>

<style>
  .recent h2 {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.95rem;
    margin: 32px 0 12px;
    color: var(--sub);
  }
  .list { display: grid; gap: 8px; }
  .item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 13px 18px;
    text-decoration: none;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .item :global(.go) { color: var(--accent); }
  .more {
    display: inline-block;
    margin-top: 14px;
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .more:hover { text-decoration: underline; }
</style>
