---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const all = await getCollection("briefings");
  return all.map((b) => ({ params: { id: b.id }, props: { entry: b } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : raw + "/";
---

<Base title={`아침 시장 브리핑 — ${entry.id}`}>
  <article class="card prose" style="padding: 10px 28px 28px;">
    <Content />
  </article>
  <p style="margin-top: 20px;">
    <a href={base} style="color: var(--accent); text-decoration: none;">← 최신 브리핑으로</a>
  </p>
</Base>
