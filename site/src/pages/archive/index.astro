---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : raw + "/";
const all = (await getCollection("briefings")).sort((a, b) => b.id.localeCompare(a.id));

// 월별 그룹핑
const byMonth = {};
for (const b of all) {
  const month = b.id.slice(0, 7); // YYYY-MM
  (byMonth[month] ??= []).push(b);
}
const months = Object.keys(byMonth).sort().reverse();
---

<Base title="아카이브 — 아침 시장 브리핑">
  <header class="hero">
    <p class="hero-eyebrow">아카이브</p>
    <h1 class="hero-date">브리핑 아카이브</h1>
    <p class="hero-sum">지난 브리핑을 월별로 모았습니다. 총 {all.length}건.</p>
  </header>
  {months.length === 0 && <p>아직 브리핑이 없습니다.</p>}
  {months.map((m) => (
    <section>
      <div class="eyebrow"><span class="tag">{m}</span> <span class="line"></span></div>
      <div class="grid">
        {byMonth[m].map((b, i) => (
          <a class="card card-lift day" data-reveal data-glow style={`--i:${i}`} href={`${base}briefings/${b.id}/`}>{b.id.slice(8)}일</a>
        ))}
      </div>
    </section>
  ))}
</Base>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    gap: 8px;
  }
  .day {
    text-align: center;
    padding: 12px 6px;
    text-decoration: none;
    color: var(--text);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .day:hover { color: var(--accent); }
</style>
