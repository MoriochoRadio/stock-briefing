---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { base } from "../../lib/base";

const all = (await getCollection("briefings")).sort((a, b) => b.id.localeCompare(a.id));

// 월별 그룹핑
const byMonth = {};
for (const b of all) {
  const month = b.id.slice(0, 7); // YYYY-MM
  (byMonth[month] ??= []).push(b);
}
const months = Object.keys(byMonth).sort().reverse();
---

<Base title="아카이브 — 아침 시장 브리핑">
  <header class="hero">
    <p class="hero-eyebrow">아카이브</p>
    <h1 class="hero-date">브리핑 아카이브</h1>
    <p class="hero-sum">지난 브리핑을 월별로 모았습니다. 총 {all.length}건.</p>
  </header>
  {months.length === 0 && (
    <div class="card empty">
      <p><strong>아직 브리핑이 없습니다.</strong></p>
      <p class="empty-sub">첫 워크플로 실행 후 날짜별 브리핑이 여기에 쌓입니다.</p>
    </div>
  )}
  {months.map((m) => (
    <section>
      <div class="eyebrow"><span class="tag">{m}</span> <span class="line"></span></div>
      <div class="grid">
        {byMonth[m].map((b, i) => (
          <a class="card card-lift day" data-reveal data-glow style={`--i:${i}`} href={`${base}briefings/${b.id}/`}>
            <time datetime={b.id}>{b.id.slice(8)}일</time>
          </a>
        ))}
      </div>
    </section>
  ))}
</Base>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    gap: 8px;
  }
  .day {
    text-align: center;
    padding: 12px 6px;
    text-decoration: none;
    color: var(--text);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .day:hover { color: var(--accent); }
  .empty { padding: 26px 22px; }
  .empty p { margin: 0 0 4px; }
  .empty-sub { color: var(--sub); font-size: 0.88rem; }
</style>
