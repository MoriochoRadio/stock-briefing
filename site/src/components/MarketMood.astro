---
import history from "../data/history.json";
import sentiment from "../data/sentiment.json";
import SectorHeatmap from "./SectorHeatmap.astro";
import { kindOf } from "../lib/groups";
import { summarize, avgText } from "../lib/market";
import { Activity, TrendingUp, TrendingDown, Minus, Gauge } from "@lucide/astro";

// 상단 '시장 분위기'.
//  - 내 관심종목: 워치리스트 개별주(history 최신)
//  - 한국/미국/총합: 시장 전체를 대표하는 섹터 ETF 바스켓(sentiment.json)
//  - 분야별: 섹터 ETF 등락 그대로
//  - 공포·탐욕 지수: CNN Fear & Greed(미국)
const latest = history.length ? history[history.length - 1] : null;
const watchStocks = (latest ? latest.quotes : []).filter(
  (q) => kindOf(q.ticker) === "stock" && Number.isFinite(q.change_pct),
);
const us = (sentiment.us ?? []).filter((q) => Number.isFinite(q.change_pct));
const kr = (sentiment.kr ?? []).filter((q) => Number.isFinite(q.change_pct));
const fng = sentiment.fng ?? null;

const ToneIcon = (tone) => (tone === "up" ? TrendingUp : tone === "down" ? TrendingDown : Minus);

const groups = [
  { name: "내 관심종목", items: watchStocks },
  { name: "한국시장", items: kr },
  { name: "미국시장", items: us },
  { name: "총합", items: [...us, ...kr] },
]
  .map((g) => ({ name: g.name, s: summarize(g.items) }))
  .filter((g) => g.s.count > 0);

// 공포·탐욕 게이지: 점수(0~100) → 색/라벨 톤
const fngTone = fng ? (fng.rating.includes("greed") ? "up" : fng.rating.includes("fear") ? "down" : "flat") : "flat";
const show = groups.length > 0 || fng;
---

{show && (
  <section class="mood card" data-reveal data-glow aria-label="오늘의 시장 분위기">
    <div class="mood-head">
      <Activity size={16} /> 오늘의 시장 분위기
      {sentiment.asOf && <span class="asof">{sentiment.asOf} 기준</span>}
    </div>

    {fng && (
      <div class="fng">
        <div class="fng-top">
          <span class="fng-title"><Gauge size={14} /> 공포·탐욕 지수 <span class="fng-src">미국 · CNN</span></span>
          <span class={`fng-score ${fngTone}`}>{fng.score}<em>{fng.label}</em></span>
        </div>
        <div class="fng-track"><span class="fng-marker" style={`--p:${fng.score}%`}></span></div>
        <div class="fng-scale"><span>공포</span><span>중립</span><span>탐욕</span></div>
      </div>
    )}

    {groups.length > 0 && (
      <div class="mood-grid">
        {groups.map((g) => {
          const Icon = ToneIcon(g.s.tone);
          return (
            <div class="mood-cell">
              <div class="mood-cell-top">
                <span class="mc-name">{g.name}</span>
                <span class={`mc-label ${g.s.tone}`}><Icon size={14} /> {g.s.label}</span>
              </div>
              <div class="mood-bar">
                <span class="seg up" style={`--w:${g.s.upPct}%`}></span>
                <span class="seg down" style={`--w:${g.s.downPct}%`}></span>
              </div>
              <div class="mc-meta">
                <span class="up">{g.s.ups}↑</span> <span class="down">{g.s.downs}↓</span> · 평균 {avgText(g.s.avg)}
              </div>
            </div>
          );
        })}
      </div>
    )}

    <SectorHeatmap us={us} kr={kr} />
  </section>
)}
