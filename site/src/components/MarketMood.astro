---
import history from "../data/history.json";
import sentiment from "../data/sentiment.json";
import { kindOf } from "../lib/groups";
import { Activity, TrendingUp, TrendingDown, Minus, Gauge } from "@lucide/astro";

// 상단 '시장 분위기'.
//  - 내 관심종목: 워치리스트 개별주(history 최신)
//  - 한국/미국/총합: 시장 전체를 대표하는 섹터 ETF 바스켓(sentiment.json)
//  - 분야별: 섹터 ETF 등락 그대로
//  - 공포·탐욕 지수: CNN Fear & Greed(미국)
const latest = history.length ? history[history.length - 1] : null;
const watchStocks = (latest ? latest.quotes : []).filter(
  (q) => kindOf(q.ticker) === "stock" && Number.isFinite(q.change_pct),
);
const us = (sentiment.us ?? []).filter((q) => Number.isFinite(q.change_pct));
const kr = (sentiment.kr ?? []).filter((q) => Number.isFinite(q.change_pct));
const fng = sentiment.fng ?? null;

function summarize(items) {
  const ups = items.filter((q) => q.change_pct > 0).length;
  const downs = items.filter((q) => q.change_pct < 0).length;
  const avg = items.length ? items.reduce((s, q) => s + q.change_pct, 0) / items.length : 0;
  const decided = ups + downs;
  const upPct = decided ? Math.round((ups / decided) * 100) : 50;
  let tone = "flat";
  let label = "혼조";
  if ((upPct >= 60 && avg > 0) || avg >= 0.4) { tone = "up"; label = "강세"; }
  else if ((upPct <= 40 && avg < 0) || avg <= -0.4) { tone = "down"; label = "약세"; }
  return { count: items.length, ups, downs, avg, upPct, downPct: 100 - upPct, tone, label };
}
const avgText = (v) => (v >= 0 ? "+" : "") + v.toFixed(2) + "%";
const ToneIcon = (tone) => (tone === "up" ? TrendingUp : tone === "down" ? TrendingDown : Minus);

const groups = [
  { name: "내 관심종목", items: watchStocks },
  { name: "한국시장", items: kr },
  { name: "미국시장", items: us },
  { name: "총합", items: [...us, ...kr] },
]
  .map((g) => ({ name: g.name, s: summarize(g.items) }))
  .filter((g) => g.s.count > 0);

const toSectors = (arr) =>
  [...arr]
    .map((q) => ({ name: q.name, avg: q.change_pct, tone: q.change_pct > 0 ? "up" : q.change_pct < 0 ? "down" : "flat" }))
    .sort((a, b) => b.avg - a.avg);
const usSectors = toSectors(us);
const krSectors = toSectors(kr);

// 히트맵 타일 색: 등락 강도(|%|, 4%에서 최대)로 채도, 한국식 빨강=상승
function heat(cp) {
  const toneVar = cp > 0 ? "var(--up)" : cp < 0 ? "var(--down)" : "var(--sub)";
  const pct = Math.round(Math.min(1, Math.abs(cp) / 4) * 70) + 14; // 14~84%
  const text = pct >= 46 ? "#fff" : "var(--text)";
  return `background:color-mix(in srgb, ${toneVar} ${pct}%, var(--card)); color:${text};`;
}

// 공포·탐욕 게이지: 점수(0~100) → 색/라벨 톤
const fngTone = fng ? (fng.rating.includes("greed") ? "up" : fng.rating.includes("fear") ? "down" : "flat") : "flat";
const show = groups.length > 0 || fng;
---

{show && (
  <section class="mood card" data-reveal data-glow aria-label="오늘의 시장 분위기">
    <div class="mood-head">
      <Activity size={16} /> 오늘의 시장 분위기
      {sentiment.asOf && <span class="asof">{sentiment.asOf} 기준</span>}
    </div>

    {fng && (
      <div class="fng">
        <div class="fng-top">
          <span class="fng-title"><Gauge size={14} /> 공포·탐욕 지수 <span class="fng-src">미국 · CNN</span></span>
          <span class={`fng-score ${fngTone}`}>{fng.score}<em>{fng.label}</em></span>
        </div>
        <div class="fng-track"><span class="fng-marker" style={`--p:${fng.score}%`}></span></div>
        <div class="fng-scale"><span>공포</span><span>중립</span><span>탐욕</span></div>
      </div>
    )}

    {groups.length > 0 && (
      <div class="mood-grid">
        {groups.map((g) => {
          const Icon = ToneIcon(g.s.tone);
          return (
            <div class="mood-cell">
              <div class="mood-cell-top">
                <span class="mc-name">{g.name}</span>
                <span class={`mc-label ${g.s.tone}`}><Icon size={14} /> {g.s.label}</span>
              </div>
              <div class="mood-bar">
                <span class="seg up" style={`--w:${g.s.upPct}%`}></span>
                <span class="seg down" style={`--w:${g.s.downPct}%`}></span>
              </div>
              <div class="mc-meta">
                <span class="up">{g.s.ups}↑</span> <span class="down">{g.s.downs}↓</span> · 평균 {avgText(g.s.avg)}
              </div>
            </div>
          );
        })}
      </div>
    )}

    {(usSectors.length > 0 || krSectors.length > 0) && (
      <div class="mood-sectors">
        <div class="ms-head">
          <span class="ms-cap">분야별 히트맵</span>
          <span class="ms-legend">약세 <i class="lg-bar"></i> 강세</span>
        </div>
        {[{ flag: "🇺🇸", label: "미국", list: usSectors }, { flag: "🇰🇷", label: "한국", list: krSectors }]
          .filter((row) => row.list.length > 0)
          .map((row) => (
            <div class="heat-group">
              <span class="heat-flag">{row.flag} {row.label}</span>
              <div class="heatmap">
                {row.list.map((s) => (
                  <span class="heat-tile" style={heat(s.avg)} title={`${s.name} ${avgText(s.avg)}`}>
                    <b class="ht-name">{s.name}</b>
                    <b class="ht-val">{avgText(s.avg)}</b>
                  </span>
                ))}
              </div>
            </div>
          ))}
      </div>
    )}
  </section>
)}
