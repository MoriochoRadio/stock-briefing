---
import history from "../data/history.json";
import { ChartLine } from "@lucide/astro";

// 코스피·나스닥·S&P500을 첫날=100으로 정규화한 추이 (2일 이상 누적 시 표시)
const TARGETS = [
  { ticker: "^KS11", color: "#ff4d5e" },
  { ticker: "^IXIC", color: "#5b9dff" },
  { ticker: "^GSPC", color: "#a78bfa" },
];

const series = [];
for (const { ticker, color } of TARGETS) {
  const points = [];
  let name = ticker;
  for (const snap of history) {
    const q = snap.quotes.find((x) => x.ticker === ticker);
    if (!q) continue;
    name = q.name;
    points.push({ time: snap.date, value: q.close });
  }
  if (points.length < 2) continue;
  const first = points[0].value;
  series.push({
    name,
    color,
    data: points.map((p) => ({ time: p.time, value: +((p.value / first) * 100).toFixed(2) })),
  });
}

const show = series.length > 0;
const payload = JSON.stringify(series);
---

{show && (
  <section class="card chart-card" data-reveal>
    <header class="chart-head">
      <h2 class="chart-title"><ChartLine size={16} /> 지수 추이 <span class="hint">시작일=100 기준</span></h2>
      <div class="legend">
        {series.map((s) => (
          <span class="legend-item"><i style={`background:${s.color}`}></i>{s.name}</span>
        ))}
      </div>
    </header>
    <div id="market-chart" class="chart-wrap"></div>
    <script type="application/json" id="market-chart-data" set:html={payload} />
  </section>
)}

<script>
  import { createChart, LineSeries } from "lightweight-charts";

  function themeColors() {
    const css = getComputedStyle(document.documentElement);
    return {
      text: css.getPropertyValue("--sub").trim(),
      grid: css.getPropertyValue("--border").trim(),
    };
  }

  function init() {
    const el = document.getElementById("market-chart");
    const dataEl = document.getElementById("market-chart-data");
    if (!el || !dataEl) return;

    const series = JSON.parse(dataEl.textContent ?? "[]");
    const { text, grid } = themeColors();

    const chart = createChart(el, {
      autoSize: true,
      layout: {
        background: { color: "transparent" },
        textColor: text,
        fontFamily: '"Pretendard Variable", Pretendard, sans-serif',
      },
      grid: {
        vertLines: { color: grid },
        horzLines: { color: grid },
      },
      rightPriceScale: { borderVisible: false },
      timeScale: { borderVisible: false },
      crosshair: {
        horzLine: { labelBackgroundColor: "#5b9dff" },
        vertLine: { labelBackgroundColor: "#5b9dff" },
      },
      localization: {
        priceFormatter: (v: number) => v.toFixed(1),
      },
    });

    for (const s of series) {
      const line = chart.addSeries(LineSeries, {
        color: s.color,
        lineWidth: 2,
        priceLineVisible: false,
        lastValueVisible: true,
      });
      line.setData(s.data);
    }
    chart.timeScale().fitContent();

    window.addEventListener("themechange", () => {
      const c = themeColors();
      chart.applyOptions({
        layout: { textColor: c.text },
        grid: { vertLines: { color: c.grid }, horzLines: { color: c.grid } },
      });
    });
  }

  init();
</script>

<style>
  .chart-card { margin-top: 14px; padding: 18px 20px; }
  .chart-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }
  .chart-title {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.95rem;
    margin: 0;
  }
  .hint { color: var(--sub); font-weight: 400; font-size: 0.78rem; }
  .legend { display: flex; gap: 12px; flex-wrap: wrap; }
  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--sub);
    font-size: 0.8rem;
    font-weight: 600;
  }
  .legend-item i {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    display: inline-block;
  }
  .chart-wrap { position: relative; height: 280px; }
</style>
