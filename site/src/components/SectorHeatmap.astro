---
import { heatStyle, avgText } from "../lib/market";

// 섹터 ETF 등락을 강도 색칠 히트맵으로. MarketMood·대시보드에서 공용.
const { us = [], kr = [], bare = false } = Astro.props as {
  us?: { name: string; change_pct: number }[];
  kr?: { name: string; change_pct: number }[];
  bare?: boolean;
};

const toSec = (arr) =>
  [...arr]
    .filter((q) => Number.isFinite(q.change_pct))
    .map((q) => ({ name: q.name, avg: q.change_pct }))
    .sort((a, b) => b.avg - a.avg);

const groups = [
  { flag: "🇺🇸", label: "미국", list: toSec(us) },
  { flag: "🇰🇷", label: "한국", list: toSec(kr) },
].filter((g) => g.list.length > 0);
---

{groups.length > 0 && (
  <div class={bare ? "mood-sectors bare" : "mood-sectors"}>
    {!bare && (
      <div class="ms-head">
        <span class="ms-cap">분야별 히트맵</span>
        <span class="ms-legend">약세 <i class="lg-bar"></i> 강세</span>
      </div>
    )}
    {groups.map((row) => (
      <div class="heat-group">
        <span class="heat-flag">{row.flag} {row.label}</span>
        <div class="heatmap">
          {row.list.map((s) => (
            <span class="heat-tile" style={heatStyle(s.avg)} title={`${s.name} ${avgText(s.avg)}`}>
              <b class="ht-name">{s.name}</b>
              <b class="ht-val">{avgText(s.avg)}</b>
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
)}
