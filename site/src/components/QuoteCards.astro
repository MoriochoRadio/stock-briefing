---
import history from "../data/history.json";

const latest = history.length ? history[history.length - 1] : null;
const fmt = (n) => n >= 1000 ? n.toLocaleString("ko-KR") : String(n);
const cls = (p) => (p > 0 ? "up" : p < 0 ? "down" : "flat");
const arrow = (p) => (p > 0 ? "▲" : p < 0 ? "▼" : "—");
---

{latest && (
  <section class="quotes">
    <p class="asof">시세 기준: {latest.date}</p>
    <div class="grid">
      {latest.quotes.map((q) => (
        <div class="card quote">
          <div class="name">{q.name}</div>
          <div class="close">{fmt(q.close)}</div>
          <div class={`chg ${cls(q.change_pct)}`}>
            {arrow(q.change_pct)} {Math.abs(q.change_pct).toFixed(2)}%
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .asof { color: var(--sub); font-size: 0.8rem; margin: 0 0 10px; }
  .grid {
    display: grid; gap: 10px;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  }
  .quote { padding: 14px 16px; }
  .name { color: var(--sub); font-size: 0.82rem; }
  .close { font-size: 1.18rem; font-weight: 700; margin: 2px 0; font-variant-numeric: tabular-nums; }
  .chg { font-size: 0.85rem; font-weight: 600; }
</style>
