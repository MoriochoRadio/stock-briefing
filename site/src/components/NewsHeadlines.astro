---
import news from "../data/news.json";
import { ExternalLink } from "@lucide/astro";

const items = (news.items ?? []).slice(0, 9);
function shortDate(pub: string) {
  if (!pub) return "";
  const d = new Date(pub);
  if (Number.isNaN(d.getTime())) return "";
  return `${String(d.getMonth() + 1).padStart(2, "0")}.${String(d.getDate()).padStart(2, "0")}`;
}
---

{items.length > 0 && (
  <section class="card news" data-reveal>
    <ul class="news-list">
      {items.map((n) => (
        <li class="news-item">
          <a class="news-link" href={n.link} target="_blank" rel="noopener noreferrer">
            <span class="news-cat">{n.cat}</span>
            <span class="news-title">{n.title}</span>
            <span class="news-meta">{n.source}{shortDate(n.pub) && <> · {shortDate(n.pub)}</>} <ExternalLink size={11} /></span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .news { padding: 5px; }
  .news-list { list-style: none; margin: 0; padding: 0; }
  .news-item + .news-item { border-top: 1px solid var(--border-soft); }
  .news-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 11px 13px;
    border-radius: 10px;
    text-decoration: none;
    color: var(--text);
    transition: background-color 0.15s ease;
  }
  .news-link:hover { background: var(--card-hover); }
  .news-link:hover .news-title { color: var(--accent); }
  .news-cat {
    flex-shrink: 0;
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 13%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
    padding: 3px 8px;
    border-radius: 6px;
    white-space: nowrap;
  }
  .news-title {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.45;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.15s ease;
  }
  .news-meta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    color: var(--sub);
    font-size: 0.74rem;
    font-weight: 600;
    white-space: nowrap;
  }
  @media (max-width: 560px) {
    .news-link { grid-template-columns: auto 1fr; row-gap: 5px; }
    .news-title { white-space: normal; }
    .news-meta { grid-column: 1 / -1; }
  }
</style>
