---
// 렌더된 마크다운을 h2 기준으로 섹션 카드로 분리하고 목차 점프 링크를 만든다.
// 정적 빌드 산출물에 동기 인라인 스크립트로 적용되어 첫 페인트 전에 재배치된다.
---

<nav id="briefing-toc" class="toc" hidden aria-label="브리핑 목차"></nav>
<article id="briefing-body" class="prose rise"><slot /></article>

<script is:inline>
  (function () {
    var root = document.getElementById("briefing-body");
    var toc = document.getElementById("briefing-toc");
    if (!root) return;

    var kids = Array.prototype.slice.call(root.children);
    var head = document.createElement("header");
    head.className = "b-head";
    var sections = [];
    var current = null;

    kids.forEach(function (node) {
      if (node.tagName === "HR") {
        node.remove(); // 카드 구분이 대신하므로 수평선 제거
        return;
      }
      if (node.tagName === "H2") {
        current = document.createElement("section");
        current.className = "b-section";
        current.appendChild(node);
        sections.push({ el: current, h2: node });
      } else if (current) {
        current.appendChild(node);
      } else {
        head.appendChild(node);
      }
    });

    if (sections.length === 0) return; // h2 없는 본문은 그대로 둔다

    root.textContent = "";
    if (head.childNodes.length) {
      head.setAttribute("data-reveal", "");
      root.appendChild(head);
    }
    sections.forEach(function (s, i) {
      if (!s.h2.id) s.h2.id = "sec-" + (i + 1);
      s.el.setAttribute("data-reveal", "");
      s.el.style.setProperty("--i", String(i));
      root.appendChild(s.el);
    });

    // 표는 모바일 가로 스크롤 래퍼로 감싼다
    Array.prototype.forEach.call(root.querySelectorAll("table"), function (table) {
      var wrap = document.createElement("div");
      wrap.className = "table-wrap";
      table.parentNode.insertBefore(wrap, table);
      wrap.appendChild(table);
    });

    // 목차 점프 링크
    if (toc && sections.length > 1) {
      sections.forEach(function (s) {
        var a = document.createElement("a");
        a.href = "#" + s.h2.id;
        a.textContent = (s.h2.textContent || "").trim();
        toc.appendChild(a);
      });
      toc.hidden = false;
    }

    // 읽기 진행바 — 본문을 지나는 스크롤 비율을 상단 바로 표시
    var bar = document.createElement("div");
    bar.className = "read-progress";
    document.body.appendChild(bar);
    var updateProgress = function () {
      var top = root.getBoundingClientRect().top + window.scrollY;
      var span = root.offsetHeight - window.innerHeight;
      var p = span > 0 ? (window.scrollY - top) / span : 0;
      bar.style.width = Math.max(0, Math.min(1, p)) * 100 + "%";
    };
    window.addEventListener("scroll", updateProgress, { passive: true });
    window.addEventListener("resize", updateProgress, { passive: true });
    updateProgress();

    // 스크롤스파이 — 현재 보이는 섹션의 목차 링크를 강조
    if (toc && sections.length > 1 && "IntersectionObserver" in window) {
      var links = toc.querySelectorAll("a");
      var spy = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (!en.isIntersecting) return;
          var id = en.target.querySelector("h2").id;
          links.forEach(function (a) {
            var on = a.getAttribute("href") === "#" + id;
            a.classList.toggle("active", on);
            if (on) {
              // 활성 링크를 목차(가로 스크롤) 중앙으로만 이동 — 페이지 세로 스크롤은 건드리지 않음
              var target = a.offsetLeft - toc.clientWidth / 2 + a.clientWidth / 2;
              toc.scrollTo({ left: target, behavior: "smooth" });
            }
          });
        });
      }, { rootMargin: "-22% 0px -68% 0px" });
      sections.forEach(function (s) { spy.observe(s.el); });
    }
  })();
</script>
